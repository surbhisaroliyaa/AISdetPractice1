<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross-Browser Suite" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Chromium Smoke">
        <parameter name="browser" value="chromium"/>
        <classes>
            <class name="tests.smoke.NavigationSmokeTest"/>
        </classes>
    </test>

    <test name="Firefox Smoke">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.smoke.NavigationSmokeTest"/>
        </classes>
    </test>

    <test name="WebKit Smoke">
        <parameter name="browser" value="webkit"/>
        <classes>
            <class name="tests.smoke.NavigationSmokeTest"/>
        </classes>
    </test>

</suite>
